{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gateforge.local/schemas/modeling_ir_v0.schema.json",
  "title": "Modeling IR v0",
  "type": "object",
  "required": [
    "schema_version",
    "model_name",
    "components",
    "connections",
    "structural_balance",
    "simulation",
    "validation_targets"
  ],
  "properties": {
    "schema_version": {"const": "modeling_ir_v0"},
    "model_name": {"type": "string", "minLength": 1},
    "source_meta": {
      "type": "object",
      "properties": {
        "domain": {"type": "string"},
        "task_id": {"type": "string"},
        "scale": {"type": "string"}
      },
      "additionalProperties": true
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "params"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
          "type": {"type": "string", "minLength": 1},
          "params": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                {"type": "number"},
                {"type": "boolean"},
                {"type": "string"}
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$"},
          "to": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$"}
        },
        "additionalProperties": false
      }
    },
    "structural_balance": {
      "type": "object",
      "required": ["variable_count", "equation_count"],
      "properties": {
        "variable_count": {"type": "integer", "minimum": 1},
        "equation_count": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "simulation": {
      "type": "object",
      "required": ["start_time", "stop_time", "number_of_intervals", "tolerance", "method"],
      "properties": {
        "start_time": {"type": "number"},
        "stop_time": {"type": "number", "exclusiveMinimum": 0},
        "number_of_intervals": {"type": "integer", "minimum": 1},
        "tolerance": {"type": "number", "exclusiveMinimum": 0},
        "method": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "validation_targets": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false
}
