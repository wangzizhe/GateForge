# LLM configuration
# LLM_MODEL is required. It is the exact model id passed to the provider API.
# Example: LLM_MODEL=gemini-2.5-flash-lite or LLM_MODEL=moonshot-v1-8k
LLM_MODEL=

# LLM_PROVIDER is optional. If omitted, the provider is inferred from LLM_MODEL.
# Supported values: gemini, openai, anthropic, qwen, deepseek, minimax, kimi, glm
# Only required when the model name is ambiguous or does not match known patterns.
LLM_PROVIDER=

# Provider-specific API keys (at least one must be set for the chosen provider)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
