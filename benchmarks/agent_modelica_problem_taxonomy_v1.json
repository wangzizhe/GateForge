        "variable_count_greater_than_equation_count",
        "state_without_dynamics_equation",
        "dangling_connector_flow_balance"
      ],
      "patch_objective": "add_missing_governing_equations_or_connector_balance",
      "mutation_operators": [
        "drop_state_equation",
        "remove_connector_balance_equation",
        "remove_conservation_constraint"
      ]
    },
    {
      "failure_type": "overconstrained_system",
      "expected_stage": "check",
      "category": "equation_balance",
      "severity": "high",
